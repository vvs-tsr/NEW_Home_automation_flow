# .env.example
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore.
#
#   cp .env.example .env
#   (then open .env and fill in the values below)

# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
LLM_MODEL=

# ── MQTT Broker ───────────────────────────────────────────────────────────────
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=
MQTT_USERNAME=
MQTT_PASSWORD=

# ── Piper TTS ─────────────────────────────────────────────────────────────────
# PIPER_MODEL_PATH is the folder containing .onnx files (default: main files/voices)
PIPER_MODEL_PATH=
PIPER_VOICE=

# ── Whisper STT ───────────────────────────────────────────────────────────────
# WHISPER_MODEL: tiny | base | small | medium | large-v3
# WHISPER_DEVICE: cuda | cpu
WHISPER_MODEL=
WHISPER_DEVICE=

# ── UDP / ESP32 ───────────────────────────────────────────────────────────────
# UDP_HOST: IP address of your ESP32 on the local network
UDP_HOST=
UDP_AUDIO_PORT=
UDP_CONTROL_PORT=
UDP_SPEAKER_PORT=

# ── Database ──────────────────────────────────────────────────────────────────
# DB_PATH: path to SQLite file (default: memory/echobud.db)
DB_PATH=

# ── Camera / YOLO ─────────────────────────────────────────────────────────────
# CAMERA_SOURCE: IP Webcam URL, e.g. http://192.168.1.50:8080/video
CAMERA_SOURCE=
# YOLO_MODEL_PATH: model file, e.g. yolov8n.pt or yolov8s.pt
YOLO_MODEL_PATH=
